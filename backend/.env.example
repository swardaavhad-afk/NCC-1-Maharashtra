# =============================================
# NCC 1 Maharashtra - Environment Variables
# Copy this file to .env and fill in real values
# =============================================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ncc_maharashtra

# JWT Secret (change in production!)
JWT_SECRET=ncc_maharashtra_jwt_secret_change_this_in_production_2026

# Supabase Configuration
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage Bucket Names
SUPABASE_BUCKET_MATERIALS=ncc-study-materials
SUPABASE_BUCKET_ATTENDANCE=ncc-attendance-photos
SUPABASE_BUCKET_CERTIFICATES=ncc-certificates
