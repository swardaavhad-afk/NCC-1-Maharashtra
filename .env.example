# Environment Variables for NCC 01 MAH AIR SQN CMS
# Copy this file to .env or backend/.env and update the values with your own keys

# Server Configuration
PORT=5000
NODE_ENV=production

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Frontend Configuration (Optional, for strictly trusting requests from a specific origin)
# FRONTEND_URL=https://your-frontend-domain.com

# Authentication (If using custom JWT outside of Supabase Auth)
# JWT_SECRET=your_jwt_secret